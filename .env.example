APP_NAME="AI Text Detector Service"
DATABASE_URL="postgresql+psycopg://ai_detector:ai_detector@postgres:5432/ai_detector"

OCR_MODEL_NAME="cyrillic-trocr/trocr-handwritten-cyrillic"
OCR_MODEL_LOCAL_FILES_ONLY=false
OCR_PRELOAD_ON_STARTUP=false
OCR_MIN_LINE_HEIGHT=20
OCR_LINE_THRESHOLD_RATIO=0.02
OCR_LINE_PADDING=15
THRESHOLD=0.5
MAX_TEXT_LENGTH=20000
UPLOAD_MAX_BYTES=8388608
PDF_MAX_PAGES=20
PDF_RENDER_DPI=200

USE_MOCK_DETECTOR=true
MODEL_BASE_PATH=Qwen/Qwen2.5-7B-Instruct
LORA_ADAPTER_PATH=./models/r_detect_qwen3
USE_ENSEMBLE_DETECTOR=false
ENSEMBLE_QWEN_BASE_PATH=Qwen/Qwen2.5-7B-Instruct
ENSEMBLE_QWEN_ADAPTER_PATH=./models/r_detect_qwen3
ENSEMBLE_T_LITE_BASE_PATH=t-tech/T-lite-it-1.0
ENSEMBLE_T_LITE_ADAPTER_PATH=./models/r_detect_t_lite_v2
ENSEMBLE_QWEN_WEIGHT=0.3360
ENSEMBLE_T_LITE_WEIGHT=0.3279
ENSEMBLE_EMBED_WEIGHT=0.3360
ENSEMBLE_USE_META_LEARNER=false
ENSEMBLE_META_LEARNER_PATH=./models/meta_learner_3models.pkl
ENSEMBLE_META_FEATURE_ORDER=t_lite,qwen,embed
EMBEDDING_ENABLED=false
EMBEDDING_BASE_PATH=deepvk/USER-bge-m3
EMBEDDING_WEIGHTS_PATH=./models/r_embed_final/model.safetensors
EMBEDDING_REFERENCE_DATASET_PATH=./datasets/final_prepared/final_train.csv
EMBEDDING_AI_REFERENCE_TEXTS_PATH=
EMBEDDING_HUMAN_REFERENCE_TEXTS_PATH=
EMBEDDING_KNN_K=5
EMBEDDING_MAX_LENGTH=512
LOAD_IN_4BIT=true
MODEL_MAX_LENGTH=256
AI_CLASS_INDEX=1
MODEL_INVERT_PROBABILITY=false
ALLOW_CPU_MODEL_LOAD=false
MODEL_LOCAL_FILES_ONLY=false

# Отключает Hugging Face Xet downloader. Полезно, если загрузка модели зависает на Fetching files.
HF_HUB_DISABLE_XET=1
HF_HUB_ENABLE_HF_TRANSFER=0

# Нужен в Docker, если OCR-модель скачивается с Hugging Face.
# Создаётся на https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=
HF_TOKEN=

# Keycloak / роли учителей
# При false приложение работает локально от имени DEMO_TEACHER_USERNAME.
AUTH_ENABLED=false
KEYCLOAK_BASE_URL="http://localhost:8080"
# В Docker браузер ходит на localhost, backend-контейнер - на service name keycloak.
KEYCLOAK_PUBLIC_BASE_URL="http://localhost:8080"
KEYCLOAK_INTERNAL_BASE_URL="http://keycloak:8080"
KEYCLOAK_REALM="school"
KEYCLOAK_CLIENT_ID="ai-detector-web"
# Оставьте пустым, если не хотите проверять aud в access token.
KEYCLOAK_AUDIENCE=
KEYCLOAK_ALGORITHMS="RS256"
ADMIN_ROLE="admin"
ADMIN_USERNAMES="admin.teacher,admin.teacher@example.test"
TEACHER_ROLE="teacher"
DEMO_TEACHER_USERNAME="demo.teacher"
CLASS_ACCESS_CLAIM="school_classes"
