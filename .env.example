APP_NAME="AI Text Detector Service"
DATABASE_URL="sqlite:///./data/results.db"

OCR_LANG="rus+eng"
THRESHOLD=0.73
MAX_TEXT_LENGTH=20000
UPLOAD_MAX_BYTES=8388608

# true - веб-сервис работает с детерминированной заглушкой.
# false - загружается реальная модель из MODEL_BASE_PATH / LORA_ADAPTER_PATH.
USE_MOCK_DETECTOR=true

# Пример для r_detect_retrain из llm-detect-ai:
# MODEL_BASE_PATH="mistralai/Mistral-7B-v0.1"
# LORA_ADAPTER_PATH="./models/r_detect_retrain/best"
MODEL_BASE_PATH=
LORA_ADAPTER_PATH=
LOAD_IN_4BIT=true
MODEL_MAX_LENGTH=256
AI_CLASS_INDEX=1
ALLOW_CPU_MODEL_LOAD=false
# true - не ходить в сеть, использовать только заранее скачанный ./hf-cache.
MODEL_LOCAL_FILES_ONLY=false
# Отключает Hugging Face Xet downloader. Полезно, если Mistral зависает на Fetching files.
HF_HUB_DISABLE_XET=1
HF_HUB_ENABLE_HF_TRANSFER=0

# Нужен в Docker, если base model скачивается с Hugging Face.
# Создаётся на https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=
HF_TOKEN=
