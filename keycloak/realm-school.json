{
  "realm": "school",
  "enabled": true,
  "displayName": "School Journal",
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 43200,
  "clientSessionIdleTimeout": 28800,
  "clientSessionMaxLifespan": 43200,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "teacher",
        "description": "Teacher can see only classes assigned to their username."
      },
      {
        "name": "admin",
        "description": "Admin can see all classes."
      }
    ]
  },
  "clients": [
    {
      "clientId": "ai-detector-web",
      "name": "AI Detector Web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://127.0.0.1:8000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8000/*##http://127.0.0.1:8000/*"
      },
      "protocolMappers": [
        {
          "name": "school_classes",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "school_classes",
            "claim.name": "school_classes",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo.teacher",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Teacher",
      "email": "demo.teacher@example.test",
      "attributes": {
        "school_classes": [
          "8А"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "teacher",
          "temporary": false
        }
      ],
      "realmRoles": [
        "teacher"
      ]
    },
    {
      "username": "second.teacher",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Second",
      "lastName": "Teacher",
      "email": "second.teacher@example.test",
      "attributes": {
        "school_classes": [
          "9Б"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "teacher",
          "temporary": false
        }
      ],
      "realmRoles": [
        "teacher"
      ]
    },
    {
      "username": "admin.teacher",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Teacher",
      "email": "admin.teacher@example.test",
      "attributes": {
        "school_classes": [
          "8А",
          "9Б"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "teacher"
      ]
    }
  ]
}
